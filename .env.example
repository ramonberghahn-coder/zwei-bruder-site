# Local (opcional — produção usa Neon/Postgres na Render)
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# URL Direct do Neon, sem "-pooler" no host. Opcional.
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

ADMIN_PASSWORD="sua-senha-forte"
SESSION_SECRET="string-aleatoria-com-pelo-menos-32-caracteres"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Armazenamento gratuito das imagens (Cloudinary)
# Crie um preset unsigned no Cloudinary ou use API key/secret para upload assinado.
CLOUDINARY_CLOUD_NAME="seu-cloud-name"
CLOUDINARY_UPLOAD_PRESET="seu-preset-unsigned"
# CLOUDINARY_API_KEY="sua-api-key"
# CLOUDINARY_API_SECRET="seu-api-secret"
CLOUDINARY_UPLOAD_FOLDER="zwei-bruder-store"

# Opcional: usar o painel /admin deste app para cadastrar produtos no WooCommerce.
# Crie as chaves em WordPress → WooCommerce → Configurações → Avançado → REST API.
WOOCOMMERCE_URL="https://www.zweibruder.com.br"
WOOCOMMERCE_CONSUMER_KEY="ck_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WOOCOMMERCE_CONSUMER_SECRET="cs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
